<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.feilong.im.mapper.ImConvMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.feilong.im.entity.ImConv">
        <id column="id" property="id" />
        <result column="type" property="type" />
        <result column="user1_id" property="user1Id" />
        <result column="user2_id" property="user2Id" />
        <result column="group_id" property="groupId" />
        <result column="last_msg_id" property="lastMsgId" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, type, user1_id, user2_id, group_id, last_msg_id, create_time, update_time
    </sql>

    <!-- im会话表分页列表 -->
    <select id="page" resultType="com.feilong.im.dto.bo.ImConvBO">
        <!-- 使用bind标签调用Java静态方法并将结果存储到变量 -->
        <bind name="safeSorts" value="@com.feilong.im.util.MyBatisUtil@getSafeSorts(pageQuery)"/>
        SELECT
        <include refid="Base_Column_List"/>
        FROM
        `im_conv`
        <where>
            <if test="pageQuery.id != null">
                AND `id` = #{pageQuery.id}
            </if>
            <if test="pageQuery.type != null">
                AND `type` =  #{pageQuery.type}
            </if>
            <if test="pageQuery.user1Id != null">
                AND `user1_id` =  #{pageQuery.user1Id}
            </if>
            <if test="pageQuery.user2Id != null">
                AND `user2_id` =  #{pageQuery.user2Id}
            </if>
            <if test="pageQuery.groupId != null">
                AND `group_id` =  #{pageQuery.groupId}
            </if>
            <if test="pageQuery.lastMsgId != null">
                AND `last_msg_id` =  #{pageQuery.lastMsgId}
            </if>
            <if test="pageQuery.createTime != null">
                AND `create_time` =  #{pageQuery.createTime}
            </if>
            <if test="pageQuery.updateTime != null">
                AND `update_time` =  #{pageQuery.updateTime}
            </if>
            <if test="pageQuery.startTime != null">
                AND `created_time` &gt;=  #{pageQuery.startTime}
            </if>
            <if test="pageQuery.endTime != null">
                AND `created_time` &lt;= #{pageQuery.endTime}
            </if>
        </where>
        <if test="safeSorts != null and safeSorts.size() > 0">
            ORDER BY
            <foreach item="sort" index="index" collection="safeSorts" separator=",">
                ${sort.field} ${sort.order}
            </foreach>
        </if>
    </select>
</mapper>
