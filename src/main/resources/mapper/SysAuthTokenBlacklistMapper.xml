<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.feilong.im.mapper.SysAuthTokenBlacklistMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.feilong.im.entity.SysAuthTokenBlacklist">
        <result column="id" property="id" />
        <result column="token" property="token" />
        <result column="deleted" property="deleted" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, token, deleted, create_time, update_time
    </sql>

    <!-- 认证token 黑名单分页列表 -->
    <select id="page" resultType="com.feilong.im.dto.bo.SysAuthTokenBlacklistBO">
        <!-- 使用bind标签调用Java静态方法并将结果存储到变量 -->
        <bind name="safeSorts" value="@com.feilong.im.util.MyBatisUtil@getSafeSorts(pageQuery)"/>
        SELECT
        <include refid="Base_Column_List"/>
        FROM
        `sys_auth_token_blacklist`
        <where>
            <if test="pageQuery.id != null and pageQuery.id.trim().length > 0">
                AND `id` LIKE CONCAT('%',  #{pageQuery.id},'%')
            </if>
            <if test="pageQuery.token != null and pageQuery.token.trim().length > 0">
                AND `token` LIKE CONCAT('%',  #{pageQuery.token},'%')
            </if>
            <if test="pageQuery.deleted != null">
                AND `deleted` =  #{pageQuery.deleted}
            </if>
            <if test="pageQuery.createTime != null">
                AND `create_time` =  #{pageQuery.createTime}
            </if>
            <if test="pageQuery.updateTime != null">
                AND `update_time` =  #{pageQuery.updateTime}
            </if>
            <if test="pageQuery.startTime != null">
                AND `created_time` &gt;=  #{pageQuery.startTime}
            </if>
            <if test="pageQuery.endTime != null">
                AND `created_time` &lt;= #{pageQuery.endTime}
            </if>
        </where>
        <if test="safeSorts != null and safeSorts.size() > 0">
            ORDER BY
            <foreach item="sort" index="index" collection="safeSorts" separator=",">
                ${sort.field} ${sort.order}
            </foreach>
        </if>
    </select>
</mapper>
